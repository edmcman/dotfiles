#!/usr/bin/env bash

function rm-old-files() {
    source "$DOROTHY/sources/bash.bash"

    show_help() {
        echo "Usage: $0 [-n|--dry-run] [-s|--since \"date string\"] [/optional/path]"
        echo "Remove files modified before the given date (default: 30 days ago)."
        echo "  -h, --help     Display this help message and exit."
        echo "  -n, --dry-run  Print files that would be removed without removing them."
        echo "  -s, --since    A date string understood by 'date', e.g., '30 days ago'."
        echo "  /optional/path Directory to remove from (default: current directory)."
    }

    local dry_run=no
    local list_args=()

    args=$(getopt -o hns: -l help,dry-run,since: -- "$@") || { show_help; exit 1; }
    eval set -- "$args"
    while true; do
        case "$1" in
            -h|--help)     show_help; exit 0 ;;
            -n|--dry-run)  dry_run=yes; shift ;;
            -s|--since)    list_args+=(-s "$2"); shift 2 ;;
            --)            shift; break ;;
        esac
    done
    [[ $# -gt 0 ]] && list_args+=("$1")

    if [[ "$dry_run" == yes ]]; then
        list-old-files -z "${list_args[@]}" | xargs -n 1 -0 echo Would remove:
    else
        list-old-files -z "${list_args[@]}" | xargs -0 rm
    fi

}

# fire if invoked standalone
if test "$0" = "${BASH_SOURCE[0]}"; then
	rm-old-files "$@"
fi