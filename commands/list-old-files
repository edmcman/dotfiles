#!/usr/bin/env bash

function list-old-files() {
    source "$DOROTHY/sources/bash.bash"

    show_help() {
        echo "Usage: $0 [-s|--since \"date string\"] [-z|--print0] [/optional/path]"
        echo "Finds files modified before the given date (default: 30 days ago)."
        echo "  -h, --help     Display this help message and exit."
        echo "  -s, --since    A date string understood by 'date', e.g., '30 days ago'."
        echo "  -z, --print0   Terminate output with NUL bytes instead of newlines (for xargs -0)."
        echo "  /optional/path Directory to search (default: current directory)."
    }

    date_str="30 days ago"
    path="."
    print_mode="-print"

    args=$(getopt -o hs:z -l help,since:,print0 -- "$@") || { show_help; exit 1; }
    eval set -- "$args"
    while true; do
        case "$1" in
            -h|--help)   show_help; exit 0 ;;
            -s|--since)  date_str="$2"; shift 2 ;;
            -z|--print0) print_mode="-print0"; shift ;;
            --)          shift; break ;;
        esac
    done
    [[ $# -gt 0 ]] && path="$1"

    # Verify that a valid date string has been set
    if ! date -d "$date_str" +"%Y-%m-%d" &> /dev/null; then
        echo "Error: Invalid date format. Please provide a valid date."
        exit 1
    fi

    # Convert date string to a format acceptable by find
    ref_date=$(date -d "$date_str" +"%Y-%m-%d")

    # Use find to locate files older than the specified date with the chosen print mode
    find "$path" -type f ! -newermt "$ref_date" $print_mode

}

# fire if invoked standalone
if test "$0" = "${BASH_SOURCE[0]}"; then
	list-old-files "$@"
fi